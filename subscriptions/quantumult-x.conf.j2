[general]
server_check_url=http://www.apple.com/library/test/success.html
server_check_timeout=5000
fallback_udp_policy=reject
dns_exclusion_list=*.cmpassport.com, *.jegotrip.com.cn, *.icitymobile.mobi, id6.me
udp_drop_list=STUN, QUIC

[dns]
server=223.5.5.5
server=119.29.29.29
doh-server=https://223.5.5.5/dns-query, https://doh.pub/dns-query

[server_local]
{% for pair in qx_pairs %}
trojan={{ pair.server_host }}:{{ pair.server_port }}, password={{ pair.password }}, over-tls=true, tls-host={{ pair.sni }}, tls-verification=true, tls-cert-sha256={{ pair.cert_fingerprint_hex }}, fast-open=false, udp-relay=false, tag={{ pair.name }}
{%- endfor %}

[policy]
static=PROXY{% for group in qx_exit_groups %}, {{ group.name }}{% endfor %}
{% for group in qx_exit_groups %}
url-latency-benchmark={{ group.name }}{% for proxy in group.proxies %}, {{ proxy }}{% endfor %}, check-interval=300, tolerance=0
{%- endfor %}

[filter_remote]
https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/QuantumultX/OpenAI/OpenAI.list, tag=bm_openai, force-policy=PROXY, enabled=true
https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/QuantumultX/Claude/Claude.list, tag=bm_claude, force-policy=PROXY, enabled=true
https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/QuantumultX/Gemini/Gemini.list, tag=bm_gemini, force-policy=PROXY, enabled=true
https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/QuantumultX/Proxy/Proxy.list, tag=bm_proxy, force-policy=PROXY, enabled=true
https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/QuantumultX/ChinaMax/ChinaMax.list, tag=bm_china, force-policy=direct, enabled=true

[filter_local]
{% for rule in qx_entry_direct_rules %}
{{ rule }}
{%- endfor %}
geoip, cn, direct
final, PROXY
