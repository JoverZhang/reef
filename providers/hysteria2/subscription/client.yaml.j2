mixed-port: {{ mixed_port }}
allow-lan: false
mode: rule
log-level: warning
ipv6: false

dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  use-hosts: true

  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29

  nameserver:
    - https://223.5.5.5/dns-query
    - https://doh.pub/dns-query

  nameserver-policy:
    "rule-set:bm_openai":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query

    "rule-set:bm_claude":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query

    "rule-set:bm_gemini":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query

    "rule-set:bm_proxy":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query

  proxy-server-nameserver:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

{% if pairs | length > 0 -%}
proxies:
{%- for pair in pairs %}
  - name: {{ pair.name }}
    type: hysteria2
    server: {{ pair.entry_ip }}
    port: {{ pair.entry_port }}
    password: "{{ pair.entry_password }}"
    sni: {{ pair.sni }}
    fingerprint: "{{ pair.entry_cert_fingerprint }}"
    skip-cert-verify: false
    alpn: [h3]
    udp: true
{%- endfor %}
{% else -%}
proxies: []
{%- endif %}

proxy-groups:
  - name: PROXY
    type: select
    proxies: [{% for group in exit_groups %}{{ group.name }}{% if not loop.last %}, {% endif %}{% endfor %}]
{%- for group in exit_groups %}
  - name: {{ group.name }}
    type: url-test
    proxies: [{% for proxy in group.proxies %}{{ proxy }}{% if not loop.last %}, {% endif %}{% endfor %}]
    url: https://www.gstatic.com/generate_204
    interval: 300
    timeout: 5000
    lazy: true
{%- endfor %}

rule-providers:
  bm_openai:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/OpenAI/OpenAI.yaml
    path: ./ruleset/bm_openai.yaml
    interval: 86400

  bm_claude:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Claude/Claude.yaml
    path: ./ruleset/bm_claude.yaml
    interval: 86400

  bm_gemini:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Gemini/Gemini.yaml
    path: ./ruleset/bm_gemini.yaml
    interval: 86400

  bm_proxy:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Proxy/Proxy_Classical.yaml
    path: ./ruleset/bm_proxy.yaml
    interval: 86400

  bm_china:
    type: http
    behavior: classical
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/ChinaMax/ChinaMax_Classical.yaml
    path: ./ruleset/bm_china.yaml
    interval: 86400

rules:
{%- for rule in entry_direct_rules %}
  - {{ rule }}
{%- endfor %}

  - RULE-SET,bm_openai,PROXY
  - RULE-SET,bm_claude,PROXY
  - RULE-SET,bm_gemini,PROXY

  - RULE-SET,bm_proxy,PROXY

  - RULE-SET,bm_china,DIRECT
  - GEOIP,CN,DIRECT
  - MATCH,PROXY
